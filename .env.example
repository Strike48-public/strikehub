# StrikeHub Environment Configuration
# Copy this to .env and customize for your environment

# Strike48 API Server URL (required for authentication)
STRIKE48_API_URL=https://studio.strike48.test

# Skip TLS certificate verification (for development/self-signed certs)
# MATRIX_TLS_INSECURE=true

# Logging level (info, debug, trace)
# RUST_LOG=info

# Connector versions for downloads (used by build scripts)
PICK_VERSION=v0.1.2
KUBESTUDIO_VERSION=v0.1.3

# Custom connector paths (optional - for development)
# KS_CONNECTOR_PATH=/path/to/ks-connector
# PENTEST_AGENT_PATH=/path/to/pentest-agent
